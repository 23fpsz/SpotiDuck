<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:background="@drawable/widget_slim_background"
    android:padding="0dp">

    <ImageView
        android:id="@+id/img_cover"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="#000000"
        android:src="@drawable/logo"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_toEndOf="@id/img_cover"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_fulltitle"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:paddingTop="3dp"
            android:singleLine="true"
            android:textColor="#ffffffff"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/controls_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_wrepeat"
                android:layout_width="36dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="Repeat"
                android:scaleType="fitCenter"
                android:src="@drawable/repoff" />

            <ImageButton
                android:id="@+id/btn_wprev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_weight="1.5"
                android:background="@android:color/transparent"
                android:contentDescription="Previous"
                android:scaleType="fitCenter"
                android:src="@drawable/previous" />

            <ImageButton
                android:id="@+id/btn_wplay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:contentDescription="Play/Pause"
                android:scaleType="fitCenter"
                android:src="@drawable/play" />

            <ImageButton
                android:id="@+id/btn_wnext"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_weight="1.5"
                android:background="@android:color/transparent"
                android:contentDescription="Next"
                android:scaleType="fitCenter"
                android:src="@drawable/next" />

            <ImageButton
                android:id="@+id/btn_wfav"
                android:layout_width="36dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:contentDescription="Add to Favorites"
                android:scaleType="fitCenter"
                android:src="@drawable/favoff" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>